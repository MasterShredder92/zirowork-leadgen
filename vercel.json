{
  "redirects": [
    { "source": "/", "has": [{ "type": "host", "value": "zirowork.com" }], "destination": "/home", "permanent": false },
    { "source": "/", "has": [{ "type": "host", "value": "www.zirowork.com" }], "destination": "/home", "permanent": false }
  ],
  "rewrites": [
    { "source": "/home", "destination": "/www/index.html" },
    { "source": "/privacy", "destination": "/legal/privacy-policy.html" },
    { "source": "/privacy-policy", "destination": "/legal/privacy-policy.html" },
    { "source": "/terms", "destination": "/legal/terms.html" },
    { "source": "/terms-of-service", "destination": "/legal/terms.html" },
    { "source": "/onboarding", "destination": "/onboard.html" },
    { "source": "/schools/:path*", "destination": "/schools/index.html" },
    { "source": "/dashboard", "destination": "/dashboard/index.html" },
    { "source": "/dashboard/:path*", "destination": "/dashboard/index.html" }
  ]
}
